{
  "name": "in-square/pimcore-favicon-bundle",
  "description": "Favicon generator bundle for Pimcore.",
  "type": "pimcore-bundle",
  "keywords": ["pimcore", "favicon", "pimcore-bundle"],
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/in-square/pimcore-favicon-bundle",
  "authors": [
    {
      "name": "Wladyslaw Dudko",
      "email": "w.dudko@insquare.pl",
      "homepage": "https://insquare.pl/"
    }
  ],
  "require": {
    "php": "^8.1",
    "symfony/framework-bundle": "^6.4",
    "pimcore/pimcore": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "InSquare\\PimcoreFaviconBundle\\": "src/"
    }
  },
  "extra": {
    "pimcore": {
      "bundles": [
        "InSquare\\PimcoreFaviconBundle"
      ]
    }
  }
}
